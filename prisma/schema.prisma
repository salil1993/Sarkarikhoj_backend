generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Scheme {
  id                      Int      @id @default(autoincrement())
  scheme_name             String   @map("scheme_name") @db.VarChar(512)
  slug                    String   @unique @db.VarChar(255)
  description             String   @db.Text
  shortSummary            String?  @map("short_summary") @db.Text
  min_age                 Int?
  max_age                 Int?
  income_limit            Int?     @map("income_limit")
  gender                  String?  @db.VarChar(32)
  occupation              String?  @db.VarChar(128)
  state                   String?  @db.VarChar(128)
  district                String?  @db.VarChar(128)
  category                String?  @db.VarChar(64)
  categoryId              Int?     @map("category_id")
  benefit                 String   @db.Text
  documents_required      String   @map("documents_required") @db.Text
  apply_link              String   @map("apply_link") @db.VarChar(2048)
  eligibility_rules_json  Json?    @map("eligibility_rules_json")
  ai_description          String?  @map("ai_description") @db.Text
  ai_benefits_summary     String?  @map("ai_benefits_summary") @db.Text
  ai_faqs                 Json?    @map("ai_faqs")
  publishStatus           String   @default("published") @map("publish_status") @db.VarChar(32)
  lastVerifiedAt          DateTime? @map("last_verified_at")
  featuredImageUrl        String?  @map("featured_image_url") @db.VarChar(2048)
  adminNotes              String?  @map("admin_notes") @db.Text
  complianceNotes         String?  @map("compliance_notes") @db.Text
  created_at              DateTime @default(now()) @map("created_at")
  updated_at              DateTime @updatedAt @map("updated_at")

  categoryRef          SchemeCategory?           @relation(fields: [categoryId], references: [id])
  tags                 SchemeOnTag[]
  eligibilityRules     EligibilityRule[]
  benefitRows          SchemeBenefit[]
  documentRows         DocumentRequirement[]
  engagements          SchemeEngagement[]
  faqs                 SchemeFaq[]
  savedBy              SavedScheme[]
  featuredCollectionItems FeaturedCollectionItem[]

  @@index([state, district])
  @@index([category])
  @@index([categoryId])
  @@map("schemes")
}

model SchemeCategory {
  id     Int     @id @default(autoincrement())
  slug   String  @unique @db.VarChar(64)
  label  String  @db.VarChar(128)
  sort   Int     @default(0)
  schemes Scheme[]

  @@map("scheme_categories")
}

model BlogCategory {
  id    Int           @id @default(autoincrement())
  slug  String        @unique @db.VarChar(64)
  label String        @db.VarChar(128)
  sort  Int           @default(0)
  posts SeoBlogPost[]

  @@map("blog_categories")
}

model Tag {
  id      Int           @id @default(autoincrement())
  slug    String        @unique @db.VarChar(64)
  label   String        @db.VarChar(128)
  schemes SchemeOnTag[]

  @@map("tags")
}

model SchemeOnTag {
  schemeId Int    @map("scheme_id")
  tagId    Int    @map("tag_id")
  scheme   Scheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([schemeId, tagId])
  @@map("scheme_tags")
}

model EligibilityRule {
  id        Int    @id @default(autoincrement())
  schemeId  Int    @map("scheme_id")
  criterion String @db.VarChar(64)
  operator  String @db.VarChar(16)
  value     String @db.Text
  weight    Int    @default(10)
  scheme    Scheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)

  @@index([schemeId])
  @@map("eligibility_rules")
}

model SchemeBenefit {
  id       Int     @id @default(autoincrement())
  schemeId Int     @map("scheme_id")
  title    String? @db.VarChar(256)
  body     String  @db.Text
  sort     Int     @default(0)
  scheme   Scheme  @relation(fields: [schemeId], references: [id], onDelete: Cascade)

  @@index([schemeId])
  @@map("benefits")
}

model DocumentRequirement {
  id       Int    @id @default(autoincrement())
  schemeId Int    @map("scheme_id")
  name     String @db.VarChar(512)
  sort     Int    @default(0)
  scheme   Scheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)

  @@index([schemeId])
  @@map("documents_required")
}

model SchemeEngagement {
  id        Int      @id @default(autoincrement())
  schemeId  Int      @map("scheme_id")
  type      String   @db.VarChar(16)
  userId    Int?     @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  scheme    Scheme   @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([schemeId, createdAt])
  @@index([type, createdAt])
  @@map("scheme_engagements")
}

model User {
  id         Int      @id @default(autoincrement())
  externalId String   @unique @map("external_id") @db.VarChar(64)
  email      String?  @unique @db.VarChar(255)
  profile    Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  engagements   SchemeEngagement[]
  checks        UserEligibilityCheck[]
  savedSchemes  SavedScheme[]
  notifications Notification[]

  @@map("users")
}

model UserEligibilityCheck {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  payload   Json
  results   Json
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("user_eligibility_checks")
}

model SavedScheme {
  userId   Int      @map("user_id")
  schemeId Int      @map("scheme_id")
  savedAt  DateTime @default(now()) @map("saved_at")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheme   Scheme   @relation(fields: [schemeId], references: [id], onDelete: Cascade)

  @@id([userId, schemeId])
  @@map("saved_schemes")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String   @db.VarChar(64)
  payload   Json
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model AnalyticsEvent {
  id        Int      @id @default(autoincrement())
  eventType String   @map("event_type") @db.VarChar(64)
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventType, createdAt])
  @@map("analytics_events")
}

model SchemeFaq {
  id       Int    @id @default(autoincrement())
  schemeId Int    @map("scheme_id")
  question String @db.Text
  answer   String @db.Text
  sort     Int    @default(0)
  scheme   Scheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)

  @@index([schemeId])
  @@map("scheme_faqs")
}

model SeoBlogPost {
  id                 Int           @id @default(autoincrement())
  slug               String        @unique @db.VarChar(255)
  title              String        @db.VarChar(512)
  excerpt            String?       @db.Text
  body               String        @db.Text
  faqs               Json?
  focusKeyword       String?       @map("focus_keyword") @db.VarChar(128)
  categoryId         Int?          @map("category_id")
  metaTitle          String?       @map("meta_title") @db.VarChar(512)
  metaDescription    String?       @map("meta_description") @db.Text
  ogImageUrl         String?       @map("og_image_url") @db.VarChar(2048)
  readingTimeMinutes Int?          @map("reading_time_minutes")
  authorName         String?       @map("author_name") @db.VarChar(256)
  canonicalUrl       String?       @map("canonical_url") @db.VarChar(2048)
  robots             String?       @default("index,follow") @db.VarChar(32)
  published          Boolean       @default(false)
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  blogCategory BlogCategory? @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@map("seo_blog_posts")
}

model SeoPage {
  id                   Int      @id @default(autoincrement())
  type                 String   @db.VarChar(32)
  slug                 String   @unique @db.VarChar(255)
  title                String   @db.VarChar(512)
  description          String?  @db.Text
  metaTitle            String?  @map("meta_title") @db.VarChar(512)
  metaDescription      String?  @map("meta_description") @db.Text
  canonicalUrl         String?  @map("canonical_url") @db.VarChar(2048)
  robots               String?  @default("index,follow") @db.VarChar(32)
  faqJson              Json?    @map("faq_json")
  structuredDataJson   Json?    @map("structured_data_json")
  payload              Json
  published            Boolean  @default(false)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@index([type])
  @@map("seo_pages")
}

model AdminUser {
  id           Int        @id @default(autoincrement())
  email        String     @unique @db.VarChar(255)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  role         String     @default("SUPPORT") @db.VarChar(32)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  auditLogs    AuditLog[]

  @@map("admin_users")
}

model AuditLog {
  id          Int        @id @default(autoincrement())
  adminUserId Int?       @map("admin_user_id")
  actor       String     @db.VarChar(32)
  action      String     @db.VarChar(128)
  resource    String     @db.VarChar(64)
  resourceId  String?    @map("resource_id") @db.VarChar(64)
  meta        Json?
  ip          String?    @db.VarChar(64)
  createdAt   DateTime   @default(now()) @map("created_at")
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id])

  @@index([resource, createdAt])
  @@index([adminUserId, createdAt])
  @@map("audit_logs")
}

model SiteSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @map("setting_key") @db.VarChar(128)
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model FeaturedCollection {
  id          Int                      @id @default(autoincrement())
  slug        String                   @unique @db.VarChar(128)
  title       String                   @db.VarChar(512)
  description String?                  @db.Text
  kind        String                   @db.VarChar(24)
  config      Json
  published   Boolean                  @default(false)
  sort        Int                      @default(0)
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")
  items       FeaturedCollectionItem[]

  @@map("featured_collections")
}

model FeaturedCollectionItem {
  collectionId Int                @map("collection_id")
  schemeId     Int                @map("scheme_id")
  sort         Int                @default(0)
  collection   FeaturedCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  scheme       Scheme             @relation(fields: [schemeId], references: [id], onDelete: Cascade)

  @@id([collectionId, schemeId])
  @@map("featured_collection_items")
}
