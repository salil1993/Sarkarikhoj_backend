# MySQL connection string (use connection pooling for serverless, e.g. PlanetScale or pooled URL)
# Example: mysql://USER:PASSWORD@HOST:3306/DATABASE
DATABASE_URL="mysql://user:password@localhost:3306/sarkari_schemes"

# Optional: comma-separated allowed origins for CORS (default same-origin only)
# CORS_ORIGINS="https://yourapp.vercel.app,http://localhost:3000"

# Optional: Upstash Redis for distributed rate limiting on Vercel (recommended for production)
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxx"
