# MySQL connection string for Prisma
#
# CRITICAL: The host after @ must be your provider’s REAL MySQL hostname.
# If you still see errors like "Can't reach database server at `MYSQL_HOST:3306`",
# you copied the placeholder "MYSQL_HOST" literally — replace it with the host
# shown in Hostinger hPanel → Websites → Manage → Databases (or Remote MySQL).
#
# Hostinger hostnames often look like: srvXXXX.hstgr.io (use the exact value from the panel).
# From your Mac, enable "Remote MySQL" in Hostinger and allow your public IP.
#
# Special characters in the password must be URL-encoded (e.g. @ → %40, # → %23).
#
# Example shape (fill in password and host from the panel):
# DATABASE_URL="mysql://u536139782_scheme_user:YOUR_PASSWORD@srvXXXX.hstgr.io:3306/u536139782_scheme_checker"

DATABASE_URL="mysql://user:password@localhost:3306/sarkari_schemes"

# Browser CORS: comma-separated exact Origin values (scheme + host, no trailing slash)
# Vercel: use CORS_ORIGIN (or legacy CORS_ORIGINS)
# CORS_ORIGIN="https://sarkarikhojkhabar.com,https://www.sarkarikhojkhabar.com,http://localhost:3000"

# Optional: Upstash Redis — rate limiting + API cache (trending / eligibility scores)
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxx"

# Admin APIs: import CSV, scrape probe, AI content, analytics dashboard
# ADMIN_SECRET="long-random-string"

# Optional LLM for POST /api/admin/ai-content
# GROQ_API_KEY="..."
# GROQ_MODEL="llama-3.3-70b-versatile"
# OPENAI_API_KEY="..."
# OPENAI_MODEL="gpt-4o-mini"
